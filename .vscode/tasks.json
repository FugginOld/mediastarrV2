{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Python dependencies",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "requirements.txt"
      ],
      "group": "build"
    },
    {
      "label": "Run MediaHunter (Flask)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "flask",
        "--app",
        "src.mediahunter.main",
        "run",
        "--host",
        "0.0.0.0",
        "--port",
        "7979"
      ],
      "options": {
        "env": {
          "DATA_DIR": "${workspaceFolder}/data"
        }
      },
      "isBackground": true,
      "group": "test"
    },
    {
      "label": "Run tests (pytest)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pytest",
        "-q",
        "tests"
      ],
      "group": "test"
    },
    {
      "label": "Run tests (unittest discover)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "unittest",
        "discover",
        "-s",
        "tests"
      ],
      "group": "test"
    }
  ]
}
