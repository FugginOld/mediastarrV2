{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Python dependencies",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "requirements.txt"
      ],
      "group": "build"
    },
    {
      "label": "Run MediaHunter (Flask)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "flask",
        "--app",
        "src.mediahunter.main",
        "run",
        "--host",
        "0.0.0.0",
        "--port",
        "7979"
      ],
      "options": {
        "env": {
          "DATA_DIR": "${workspaceFolder}/data"
        }
      },
      "isBackground": true,
      "group": "test"
    },
    {
      "label": "Run tests (pytest)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "pytest",
        "-q",
        "tests"
      ],
      "group": "test"
    },
    {
      "label": "Run tests (unittest discover)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": [
        "-m",
        "unittest",
        "discover",
        "-s",
        "tests"
      ],
      "group": "test"
    },
    {
      "label": "Frontend: Install dependencies",
      "type": "shell",
      "command": "npm",
      "args": [
        "install"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build"
    },
    {
      "label": "Frontend: Dev server",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "group": "test"
    },
    {
      "label": "Frontend: Build",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "build"
    },
    {
      "label": "Frontend: Verify (build + tests)",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "verify"
      ],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "group": "test"
    },
    {
      "label": "Frontend: Smoke check (Flask + SPA)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/react-spa-smoke.ps1"
      ],
      "group": "test"
    }
  ]
}
