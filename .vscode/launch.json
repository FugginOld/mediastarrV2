{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MediaHunter: Flask (Debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "cwd": "${workspaceFolder}",
      "args": [
        "--app",
        "src.mediahunter.main",
        "run",
        "--host",
        "0.0.0.0",
        "--port",
        "7979",
        "--no-reload"
      ],
      "jinja": true,
      "env": {
        "FLASK_ENV": "development",
        "DATA_DIR": "${workspaceFolder}/data"
      },
      "console": "integratedTerminal"
    }
  ]
}
